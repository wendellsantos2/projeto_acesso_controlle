---
import Layout from '../layouts/Layout.astro';
import { LogIn, Search, ShieldAlert, CheckCircle2, UserPlus, ArrowLeft } from '@lucide/astro';
---

<Layout title="Registrar Entrada" description="Registrar entrada de clientes e validação de idade.">
  <div class="animate-fade-in" style="max-width: 600px; margin: 2rem auto 0;">
    
    <!-- Navigation Back Link -->
    <a href="/" style="display: inline-flex; align-items: center; gap: 0.5rem; color: var(--text-muted); font-size: 0.9rem; margin-bottom: 1.5rem; transition: color var(--transition-fast);" onmouseover="this.style.color='var(--text-primary)'" onmouseout="this.style.color='var(--text-muted)'">
      <ArrowLeft size={16} /> Voltar para o Dashboard
    </a>

    <div class="glass-card">
      <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.5rem;">
        <div class="stat-icon-wrapper" style="--accent-color: var(--primary); --accent-glow: var(--primary-glow); width: 42px; height: 42px; border-radius: var(--radius-sm);">
          <LogIn size={20} />
        </div>
        <div>
          <h2 style="font-size: 1.5rem;">Registrar Entrada</h2>
          <p style="color: var(--text-secondary); font-size: 0.85rem;">Busque o cliente pelo nome para validar o acesso.</p>
        </div>
      </div>

      <!-- Step 1: Search -->
      <div class="form-group">
        <label for="search-input" class="form-label">Nome do Cliente</label>
        <div class="search-wrapper">
          <input 
            type="text" 
            id="search-input" 
            class="input-glass" 
            placeholder="Digite o nome para buscar..." 
            autocomplete="off"
            required
          />
          <!-- Suggestion List -->
          <div id="suggestions-list" class="suggestions-dropdown"></div>
        </div>
        <p style="color: var(--text-muted); font-size: 0.8rem; margin-top: 0.5rem;">
          Se for um cliente recorrente, basta digitar o nome.
        </p>
      </div>

      <!-- Step 2: Verification (hidden by default) -->
      <div id="verification-panel" style="display: none; border-top: 1px solid var(--border-glass); padding-top: 1.5rem; margin-top: 1.5rem;">
        <h3 class="mb-2" style="font-size: 1.1rem; color: var(--text-secondary);">Dados da Validação</h3>
        
        <div class="glass-card" style="padding: 1.25rem; background: rgba(0,0,0,0.15); margin-bottom: 1.25rem;">
          <div class="flex-between mb-1">
            <span style="font-size: 0.85rem; color: var(--text-muted);">Nome Completo</span>
            <span id="client-id-badge" style="font-size: 0.75rem; font-family: monospace; color: var(--primary);"></span>
          </div>
          <div id="client-name-val" style="font-size: 1.25rem; font-weight: 700; margin-bottom: 0.75rem;"></div>
          
          <div class="flex-between">
            <div>
              <span style="display: block; font-size: 0.85rem; color: var(--text-muted);">Nascimento</span>
              <span id="client-dob-val" style="font-weight: 500;"></span>
            </div>
            <div style="text-align: right;">
              <span style="display: block; font-size: 0.85rem; color: var(--text-muted);">Idade Atual</span>
              <span id="client-age-val" style="font-size: 1.2rem; font-weight: 700; color: var(--text-primary);"></span>
            </div>
          </div>
        </div>

        <!-- Dynamic Age Warning Alert Box -->
        <div id="age-alert-box" class="alert-box">
          <!-- Populated dynamically via JS -->
        </div>

        <!-- Action Buttons -->
        <div style="display: flex; gap: 1rem; margin-top: 1.5rem;">
          <button id="cancel-checkin-btn" class="btn btn-secondary" style="flex: 1;">Cancelar</button>
          <button id="confirm-checkin-btn" class="btn btn-primary" style="flex: 2;">
            <LogIn size={18} /> Confirmar Acesso
          </button>
        </div>
      </div>

      <!-- Step 3: Not Found / Quick Register Option -->
      <div id="not-found-panel" class="text-center" style="display: none; border-top: 1px solid var(--border-glass); padding-top: 1.5rem; margin-top: 1.5rem;">
        <p style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 1rem;">
          Nenhum cliente encontrado com este nome.
        </p>
        <a href="/register" class="btn btn-secondary btn-sm" style="gap: 0.5rem; display: inline-flex;">
          <UserPlus size={16} /> Cadastrar Novo Cliente
        </a>
      </div>

    </div>
  </div>
</Layout>

<script>
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const suggestionsList = document.getElementById('suggestions-list') as HTMLDivElement;
  const verificationPanel = document.getElementById('verification-panel') as HTMLDivElement;
  const notFoundPanel = document.getElementById('not-found-panel') as HTMLDivElement;
  
  const clientNameVal = document.getElementById('client-name-val') as HTMLDivElement;
  const clientIdBadge = document.getElementById('client-id-badge') as HTMLSpanElement;
  const clientDobVal = document.getElementById('client-dob-val') as HTMLSpanElement;
  const clientAgeVal = document.getElementById('client-age-val') as HTMLSpanElement;
  const ageAlertBox = document.getElementById('age-alert-box') as HTMLDivElement;
  
  const confirmBtn = document.getElementById('confirm-checkin-btn') as HTMLButtonElement;
  const cancelBtn = document.getElementById('cancel-checkin-btn') as HTMLButtonElement;

  let selectedClientId = '';

  // Helper to calculate age in JS
  function calculateAge(birthDateString: string) {
    const birthDate = new Date(birthDateString);
    const today = new Date();
    let age = today.getFullYear() - birthDate.getFullYear();
    const monthDiff = today.getMonth() - birthDate.getMonth();
    
    if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < birthDate.getDate())) {
      age--;
    }
    return age;
  }

  // Handle Search Input
  if (searchInput) {
    searchInput.addEventListener('input', async () => {
      const query = searchInput.value.trim();
      
      if (query.length < 2) {
        suggestionsList.innerHTML = '';
        suggestionsList.classList.remove('active');
        verificationPanel.style.display = 'none';
        notFoundPanel.style.display = 'none';
        selectedClientId = '';
        return;
      }

      try {
        const response = await fetch(`/api/clients?q=${encodeURIComponent(query)}`);
        if (response.ok) {
          const clients = await response.json();
          
          if (clients.length > 0) {
            notFoundPanel.style.display = 'none';
            suggestionsList.innerHTML = clients.map((c: any) => `
              <div class="suggestion-item" data-id="${c.id}" data-firstname="${c.firstName}" data-lastname="${c.lastName}" data-birthdate="${c.birthDate}">
                <span class="suggestion-name">${c.firstName} ${c.lastName}</span>
                <span class="suggestion-dob">${new Date(c.birthDate).toLocaleDateString('pt-BR')}</span>
              </div>
            `).join('');
            suggestionsList.classList.add('active');

            // Add Click Handlers for suggestion items
            const items = suggestionsList.querySelectorAll('.suggestion-item');
            items.forEach(item => {
              item.addEventListener('click', (e) => {
                const target = e.currentTarget as HTMLDivElement;
                const id = target.getAttribute('data-id') || '';
                const firstName = target.getAttribute('data-firstname') || '';
                const lastName = target.getAttribute('data-lastname') || '';
                const birthDate = target.getAttribute('data-birthdate') || '';
                
                selectClient(id, firstName, lastName, birthDate);
              });
            });

          } else {
            // Not found
            suggestionsList.innerHTML = '';
            suggestionsList.classList.remove('active');
            verificationPanel.style.display = 'none';
            notFoundPanel.style.display = 'block';
            selectedClientId = '';
          }
        }
      } catch (err) {
        console.error("Error searching clients:", err);
      }
    });
    
    // Close suggestions when clicking outside
    document.addEventListener('click', (e) => {
      if (e.target !== searchInput && e.target !== suggestionsList) {
        suggestionsList.classList.remove('active');
      }
    });
  }

  // Populate client details & show verification
  function selectClient(id: string, firstName: string, lastName: string, birthDate: string) {
    selectedClientId = id;
    searchInput.value = `${firstName} ${lastName}`;
    suggestionsList.innerHTML = '';
    suggestionsList.classList.remove('active');
    
    const age = calculateAge(birthDate);
    const isMinor = age < 18;
    
    // Render details
    clientIdBadge.textContent = id;
    clientNameVal.textContent = `${firstName} ${lastName}`;
    clientDobVal.textContent = new Date(birthDate).toLocaleDateString('pt-BR');
    clientAgeVal.textContent = `${age} anos`;

    // Render alert box depending on age
    if (isMinor) {
      ageAlertBox.className = 'alert-box alert-box-danger';
      ageAlertBox.innerHTML = `
        <div class="stat-icon-wrapper" style="color: var(--danger); background: var(--danger-glow); width: 32px; height: 32px; border-radius: 6px;">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        </div>
        <div>
          <div class="alert-title">ATENÇÃO: MENOR DE IDADE!</div>
          <div class="alert-desc">O cliente tem ${age} anos. Verifique se possui autorização legal e/ou acompanhamento de um responsável.</div>
        </div>
      `;
    } else {
      ageAlertBox.className = 'alert-box';
      ageAlertBox.style.backgroundColor = 'var(--success-bg)';
      ageAlertBox.style.borderColor = 'rgba(16, 185, 129, 0.3)';
      ageAlertBox.style.color = 'var(--success)';
      ageAlertBox.innerHTML = `
        <div class="stat-icon-wrapper" style="color: var(--success); background: var(--success-glow); width: 32px; height: 32px; border-radius: 6px;">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <div>
          <div class="alert-title">Acesso Autorizado (Maior de idade)</div>
          <div class="alert-desc">Cliente verificado com ${age} anos. Nenhuma restrição de faixa etária.</div>
        </div>
      `;
    }

    verificationPanel.style.display = 'block';
  }

  // Cancel check-in
  if (cancelBtn) {
    cancelBtn.addEventListener('click', () => {
      verificationPanel.style.display = 'none';
      searchInput.value = '';
      selectedClientId = '';
    });
  }

  // Confirm check-in
  if (confirmBtn) {
    confirmBtn.addEventListener('click', async () => {
      if (!selectedClientId) return;

      confirmBtn.disabled = true;
      confirmBtn.textContent = 'Processando...';

      try {
        const response = await fetch('/api/check-in', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ clientId: selectedClientId })
        });

        if (response.ok) {
          window.location.href = '/';
        } else {
          const data = await response.json();
          alert(`Erro no check-in: ${data.error || 'Falha desconhecida.'}`);
          confirmBtn.disabled = false;
          confirmBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 0.5rem;"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg> Confirmar Acesso';
        }
      } catch (err) {
        console.error(err);
        alert('Erro ao conectar com o servidor.');
        confirmBtn.disabled = false;
      }
    });
  }
</script>
