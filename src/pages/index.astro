---
import Layout from '../layouts/Layout.astro';
import { Users, LogIn, ShieldAlert, CalendarRange, Search, Activity, UserPlus, FileText } from '@lucide/astro';
---

<Layout title="Dashboard" description="Painel de controle de acesso e frequência de clientes.">
  <div class="animate-fade-in">
    <!-- Welcome Header -->
    <div class="flex-between mb-3" style="align-items: flex-start;">
      <div>
        <h1 style="font-size: 2.25rem; margin-bottom: 0.25rem;">Painel de Controle</h1>
        <p style="color: var(--text-secondary);">Gerenciamento de acessos e monitoramento de presença em tempo real.</p>
      </div>
      <div class="badge badge-info" style="padding: 0.5rem 1rem; font-size: 0.85rem; border-radius: var(--radius-sm);">
        <Activity size={14} style="margin-right: 0.5rem; animation: pulse 2s infinite;" />
        Sistema Local
      </div>
    </div>

    <!-- Stats Grid -->
    <div class="stats-grid">
      <div class="stat-card" style="--accent-color: var(--primary); --accent-glow: var(--primary-glow);">
        <div class="stat-icon-wrapper">
          <Users size={24} />
        </div>
        <div class="stat-info">
          <span class="stat-value" id="stat-total-clients">0</span>
          <span class="stat-label">Clientes Cadastrados</span>
        </div>
      </div>

      <div class="stat-card" style="--accent-color: var(--success); --accent-glow: var(--success-glow);">
        <div class="stat-icon-wrapper">
          <LogIn size={24} />
        </div>
        <div class="stat-info">
          <span class="stat-value" id="stat-present-now">0</span>
          <span class="stat-label">Presentes Agora</span>
        </div>
      </div>

      <!-- We will dynamically class the colors of the minors card based on presence -->
      <div class="stat-card" id="stat-minors-card" style="--accent-color: var(--warning); --accent-glow: var(--warning-glow);">
        <div class="stat-icon-wrapper" id="stat-minors-icon-wrapper">
          <ShieldAlert size={24} />
        </div>
        <div class="stat-info">
          <span class="stat-value" id="stat-minors-inside">0</span>
          <span class="stat-label">Menores no Local</span>
        </div>
      </div>

      <div class="stat-card" style="--accent-color: var(--primary); --accent-glow: var(--primary-glow);">
        <div class="stat-icon-wrapper">
          <CalendarRange size={24} />
        </div>
        <div class="stat-info">
          <span class="stat-value" id="stat-today-visits">0</span>
          <span class="stat-label">Visitas Hoje</span>
        </div>
      </div>
    </div>

    <!-- Main Content Layout -->
    <div class="dashboard-grid">
      
      <!-- Present Clients (Col-8) -->
      <section class="glass-card col-8">
        <h2 class="mb-2" style="font-size: 1.5rem; display: flex; align-items: center; gap: 0.5rem;">
          <Activity size={20} class="text-primary" /> Clientes no Estabelecimento
        </h2>
        <p style="color: var(--text-muted); margin-bottom: 1.5rem;">Lista de clientes que estão no local. Registre a saída ao final da visita.</p>

        <!-- No clients container -->
        <div id="no-clients-container" class="text-center" style="display: none; padding: 3rem 1rem; border: 1px dashed var(--border-glass); border-radius: var(--radius-md);">
          <LogIn size={48} class="text-muted" style="margin: 0 auto 1rem; opacity: 0.5;" />
          <h3 class="mb-1" style="font-size: 1.2rem; color: var(--text-secondary);">Nenhum cliente no local</h3>
          <p class="mb-2" style="color: var(--text-muted); font-size: 0.9rem;">Registre a entrada de um cliente para monitorar sua permanência.</p>
          <a href="/check-in" class="btn btn-primary btn-sm">Registrar Entrada</a>
        </div>

        <!-- Clients table -->
        <div id="clients-table-container" class="table-wrapper" style="display: none;">
          <table class="glass-table">
            <thead>
              <tr>
                <th>Nome do Cliente</th>
                <th>Idade</th>
                <th>Status de Idade</th>
                <th>Horário de Entrada</th>
                <th style="text-align: right;">Ação</th>
              </tr>
            </thead>
            <tbody id="presence-table-body">
              <!-- Dynamically populated -->
            </tbody>
          </table>
        </div>
      </section>

      <!-- Sidebar / Quick Actions (Col-4) -->
      <div class="col-4" style="display: flex; flex-direction: column; gap: 1.5rem;">
        
        <!-- Quick Actions Card -->
        <section class="glass-card">
          <h2 class="mb-2" style="font-size: 1.3rem;">Acesso Rápido</h2>
          <div style="display: flex; flex-direction: column; gap: 0.85rem; margin-top: 1rem;">
            <a href="/check-in" class="btn btn-primary" style="justify-content: flex-start; width: 100%;">
              <LogIn size={18} /> Registrar Entrada
            </a>
            <a href="/register" class="btn btn-secondary" style="justify-content: flex-start; width: 100%;">
              <UserPlus size={18} /> Cadastrar Cliente
            </a>
            <a href="/history" class="btn btn-secondary" style="justify-content: flex-start; width: 100%;">
              <FileText size={18} /> Histórico de Visitas
            </a>
          </div>
        </section>

        <!-- Simulated Biometric Reader Card -->
        <section class="glass-card" style="border-color: rgba(99, 102, 241, 0.25);">
          <h2 class="mb-1" style="font-size: 1.3rem; display: flex; align-items: center; gap: 0.5rem;">
            <Search size={18} class="text-primary" /> Simulador Biométrico
          </h2>
          <p class="mb-2" style="color: var(--text-muted); font-size: 0.85rem;">
            Simula um leitor biométrico ou de cartões. Digite o nome de um cliente e aperte Enter para alternar presença (entrada/saída).
          </p>

          <form id="biometric-form" style="margin-top: 1rem;">
            <div class="form-group" style="margin-bottom: 0.75rem;">
              <div class="search-wrapper">
                <input 
                  type="text" 
                  id="biometric-input" 
                  class="input-glass" 
                  placeholder="Nome do cliente cadastrado..." 
                  autocomplete="off"
                  required
                />
                <div id="biometric-suggestions" class="suggestions-dropdown"></div>
              </div>
            </div>
            <button type="submit" class="btn btn-primary btn-sm" style="width: 100%;">Processar Leitura</button>
          </form>
          <div id="biometric-feedback" style="margin-top: 0.75rem; display: none;"></div>
        </section>

      </div>
    </div>
  </div>
</Layout>

<script>
  import { getClients, getActiveVisits, getVisits, checkOut, checkOutByClientId, checkIn, calculateAge } from '../lib/clientDb';

  // Elements
  const statTotalClients = document.getElementById('stat-total-clients') as HTMLSpanElement;
  const statPresentNow = document.getElementById('stat-present-now') as HTMLSpanElement;
  const statMinorsInside = document.getElementById('stat-minors-inside') as HTMLSpanElement;
  const statTodayVisits = document.getElementById('stat-today-visits') as HTMLSpanElement;
  
  const statMinorsCard = document.getElementById('stat-minors-card') as HTMLDivElement;
  const statMinorsIconWrapper = document.getElementById('stat-minors-icon-wrapper') as HTMLDivElement;

  const noClientsContainer = document.getElementById('no-clients-container') as HTMLDivElement;
  const clientsTableContainer = document.getElementById('clients-table-container') as HTMLDivElement;
  const presenceTableBody = document.getElementById('presence-table-body') as HTMLTableSectionElement;

  const bioInput = document.getElementById('biometric-input') as HTMLInputElement;
  const bioSuggestions = document.getElementById('biometric-suggestions') as HTMLDivElement;
  const bioForm = document.getElementById('biometric-form') as HTMLFormElement;
  const bioFeedback = document.getElementById('biometric-feedback') as HTMLDivElement;

  let selectedClientId = '';

  // Formatter for timestamps
  const formatTime = (isoString: string) => {
    const date = new Date(isoString);
    return date.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });
  };

  // Main UI update function (runs on load and after any update)
  function updateDashboard() {
    const clients = getClients();
    const activeVisits = getActiveVisits();
    const allVisits = getVisits();

    // Stats calculations
    const totalClientsCount = clients.length;
    const presentNowCount = activeVisits.length;
    const minorsInsideCount = activeVisits.filter(v => v.ageAtVisit < 18).length;
    
    const todayStr = new Date().toISOString().split('T')[0];
    const todayVisitsCount = allVisits.filter(v => v.checkInAt.startsWith(todayStr)).length;

    // Update Counters in DOM
    if (statTotalClients) statTotalClients.textContent = String(totalClientsCount);
    if (statPresentNow) statPresentNow.textContent = String(presentNowCount);
    if (statMinorsInside) statMinorsInside.textContent = String(minorsInsideCount);
    if (statTodayVisits) statTodayVisits.textContent = String(todayVisitsCount);

    // Dynamic warning colors for minors inside
    if (statMinorsCard && statMinorsIconWrapper) {
      if (minorsInsideCount > 0) {
        statMinorsCard.style.setProperty('--accent-color', 'var(--danger)');
        statMinorsCard.style.setProperty('--accent-glow', 'var(--danger-glow)');
        statMinorsIconWrapper.style.color = 'var(--danger)';
        statMinorsIconWrapper.style.backgroundColor = 'var(--danger-glow)';
      } else {
        statMinorsCard.style.setProperty('--accent-color', 'var(--warning)');
        statMinorsCard.style.setProperty('--accent-glow', 'var(--warning-glow)');
        statMinorsIconWrapper.style.color = 'var(--warning)';
        statMinorsIconWrapper.style.backgroundColor = 'var(--warning-glow)';
      }
    }

    // Render Presence Table
    if (activeVisits.length === 0) {
      if (clientsTableContainer) clientsTableContainer.style.display = 'none';
      if (noClientsContainer) noClientsContainer.style.display = 'block';
    } else {
      if (noClientsContainer) noClientsContainer.style.display = 'none';
      if (clientsTableContainer) clientsTableContainer.style.display = 'block';

      if (presenceTableBody) {
        presenceTableBody.innerHTML = activeVisits.map(visit => {
          const isMinor = visit.ageAtVisit < 18;
          return `
            <tr>
              <td style="font-weight: 600;">${visit.client.firstName} ${visit.client.lastName}</td>
              <td>${visit.ageAtVisit} anos</td>
              <td>
                ${isMinor ? 
                  `<span class="badge badge-danger">Menor de Idade</span>` : 
                  `<span class="badge badge-success">Maior de Idade</span>`
                }
              </td>
              <td style="font-family: monospace; font-size: 0.95rem;">
                ${formatTime(visit.checkInAt)}
              </td>
              <td style="text-align: right;">
                <button 
                  class="btn btn-danger btn-sm checkout-action-btn" 
                  data-visit-id="${visit.id}"
                >
                  Registrar Saída
                </button>
              </td>
            </tr>
          `;
        }).join('');

        // Attach event listeners to the checkout buttons
        const checkoutBtns = presenceTableBody.querySelectorAll('.checkout-action-btn');
        checkoutBtns.forEach(btn => {
          btn.addEventListener('click', (e) => {
            const button = e.currentTarget as HTMLButtonElement;
            const visitId = button.getAttribute('data-visit-id');
            if (visitId) {
              try {
                checkOut(visitId);
                updateDashboard(); // instantly update dashboard!
              } catch (err: any) {
                alert(`Erro: ${err.message}`);
              }
            }
          });
        });
      }
    }
  }

  // Initial Load
  updateDashboard();

  // Biometric Autocomplete suggestions
  if (bioInput) {
    bioInput.addEventListener('input', () => {
      const val = bioInput.value.trim().toLowerCase();
      if (val.length < 2) {
        bioSuggestions.innerHTML = '';
        bioSuggestions.classList.remove('active');
        selectedClientId = '';
        return;
      }

      const clients = getClients().filter(c => 
        `${c.firstName} ${c.lastName}`.toLowerCase().includes(val)
      );

      if (clients.length > 0) {
        bioSuggestions.innerHTML = clients.map(c => `
          <div class="suggestion-item" data-id="${c.id}" data-name="${c.firstName} ${c.lastName}">
            <span class="suggestion-name">${c.firstName} ${c.lastName}</span>
            <span class="suggestion-dob">${new Date(c.birthDate).toLocaleDateString('pt-BR')}</span>
          </div>
        `).join('');
        bioSuggestions.classList.add('active');

        const items = bioSuggestions.querySelectorAll('.suggestion-item');
        items.forEach(item => {
          item.addEventListener('click', (e) => {
            const target = e.currentTarget as HTMLDivElement;
            const id = target.getAttribute('data-id') || '';
            const name = target.getAttribute('data-name') || '';
            bioInput.value = name;
            selectedClientId = id;
            bioSuggestions.innerHTML = '';
            bioSuggestions.classList.remove('active');
          });
        });
      } else {
        bioSuggestions.innerHTML = '<div class="suggestion-item"><span class="suggestion-dob">Nenhum cliente cadastrado</span></div>';
        bioSuggestions.classList.add('active');
        selectedClientId = '';
      }
    });

    document.addEventListener('click', (e) => {
      if (e.target !== bioInput && e.target !== bioSuggestions) {
        bioSuggestions.classList.remove('active');
      }
    });
  }

  // Biometric Form Submission
  if (bioForm) {
    bioForm.addEventListener('submit', (e) => {
      e.preventDefault();
      const clientName = bioInput.value.trim();
      if (!clientName) return;

      if (bioFeedback) {
        bioFeedback.style.display = 'block';
        bioFeedback.className = 'alert-box alert-box-warning';
        bioFeedback.innerHTML = '<div class="alert-desc">Processando leitura digital...</div>';
      }

      setTimeout(() => {
        try {
          let clientIdToUse = selectedClientId;

          if (!clientIdToUse) {
            // Find by exact case-insensitive match
            const results = getClients().filter(c => 
              `${c.firstName} ${c.lastName}`.toLowerCase() === clientName.toLowerCase()
            );
            if (results.length === 1) {
              clientIdToUse = results[0].id;
            } else if (results.length > 1) {
              bioFeedback.className = 'alert-box alert-box-danger';
              bioFeedback.innerHTML = `
                <div>
                  <div class="alert-title">Multiplos clientes encontrados</div>
                  <div class="alert-desc">Selecione um na lista de sugestões.</div>
                </div>
              `;
              return;
            }
          }

          if (!clientIdToUse) {
            bioFeedback.className = 'alert-box alert-box-danger';
            bioFeedback.innerHTML = `
              <div>
                <div class="alert-title">Cliente não encontrado</div>
                <div class="alert-desc">Nenhum cliente cadastrado com o nome "${clientName}".</div>
              </div>
            `;
            return;
          }

          // Toggle presence logic
          let operation = '';
          const activeVisits = getActiveVisits();
          const isInside = activeVisits.some(v => v.clientId === clientIdToUse);

          let visit;
          if (isInside) {
            visit = checkOutByClientId(clientIdToUse);
            operation = 'checkout';
          } else {
            visit = checkIn(clientIdToUse);
            operation = 'checkin';
          }

          // Feedback UI
          bioFeedback.className = 'alert-box';
          bioFeedback.style.backgroundColor = 'var(--success-bg)';
          bioFeedback.style.borderColor = 'rgba(16, 185, 129, 0.3)';
          bioFeedback.style.color = 'var(--success)';

          if (operation === 'checkout') {
            bioFeedback.innerHTML = `
              <div>
                <div class="alert-title">Saída Registrada!</div>
                <div class="alert-desc">Saída registrada via biometria com sucesso.</div>
              </div>
            `;
          } else {
            const isMinor = visit.ageAtVisit < 18;
            if (isMinor) {
              bioFeedback.className = 'alert-box alert-box-danger';
              bioFeedback.innerHTML = `
                <div>
                  <div class="alert-title">Entrada com Alerta (Menor de 18)!</div>
                  <div class="alert-desc">Acesso Liberado. Menor com ${visit.ageAtVisit} anos.</div>
                </div>
              `;
            } else {
              bioFeedback.innerHTML = `
                <div>
                  <div class="alert-title">Entrada Registrada!</div>
                  <div class="alert-desc">Acesso autorizado. Cliente com ${visit.ageAtVisit} anos.</div>
                </div>
              `;
            }
          }

          // Clear form and update Dashboard list/stats immediately!
          bioInput.value = '';
          selectedClientId = '';
          updateDashboard();

          // Hide feedback alert after 4 seconds
          setTimeout(() => {
            bioFeedback.style.display = 'none';
          }, 4000);

        } catch (err: any) {
          bioFeedback.className = 'alert-box alert-box-danger';
          bioFeedback.innerHTML = `
            <div>
              <div class="alert-title">Erro de Acesso</div>
              <div class="alert-desc">${err.message || 'Erro no terminal biométrico.'}</div>
            </div>
          `;
        }
      }, 800); // Small delay to simulate reading card
    });
  }
</script>

<style>
  @keyframes pulse {
    0% { opacity: 0.6; }
    50% { opacity: 1; }
    100% { opacity: 0.6; }
  }
</style>
